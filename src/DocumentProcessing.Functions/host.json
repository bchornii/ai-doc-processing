{
  "version": "2.0",
  "telemetryMode": "OpenTelemetry",
  "extensions": {
    "durableTask": {
      "storageProvider": {
        "type": "azureManaged",
        "connectionStringName": "DTS_CONNECTION_STRING"
      },
      "hubName": "%TASKHUB_NAME%"
    }
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Azure.Core": "Warning",
      "Azure.Identity": "Warning"
    }
  }
}
